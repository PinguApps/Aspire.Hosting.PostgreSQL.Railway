{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>PinguApps/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "dotnet tool install -g Aspire\\.Cli --version (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "nuget",
      "depNameTemplate": "Aspire.Cli"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)(samples/TypeScriptAppHost|tests/Aspire\\.Hosting\\.PostgreSQL\\.Railway/Fixtures/TypeScriptAppHost)/aspire\\.config\\.json$/"
      ],
      "matchStrings": [
        "\"sdk\"\\s*:\\s*\\{\\s*\"version\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "nuget",
      "depNameTemplate": "Aspire.Cli"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)(README\\.md|docs/install\\.md|samples/TypeScriptAppHost/aspire\\.config\\.json|tests/Aspire\\.Hosting\\.PostgreSQL\\.Railway/Fixtures/TypeScriptAppHost/aspire\\.config\\.json)$/"
      ],
      "matchStrings": [
        "\"Aspire\\.Hosting\\.PostgreSQL\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "nuget",
      "depNameTemplate": "Aspire.Hosting.PostgreSQL"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)AGENTS\\.md$/"
      ],
      "matchStrings": [
        "Target Aspire version:\\s*`(?<currentValue>[^`]+)`"
      ],
      "datasourceTemplate": "nuget",
      "depNameTemplate": "Aspire.Hosting"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "Aspire.Cli",
        "Aspire.Hosting",
        "Aspire.Hosting.PostgreSQL"
      ],
      "groupName": "aspire monorepo",
      "groupSlug": "aspire-monorepo"
    }
  ]
}
